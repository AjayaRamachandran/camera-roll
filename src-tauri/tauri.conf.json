{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Camera Roll",
  "version": "0.1.0",
  "identifier": "com.photoviewer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:all",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Camera Roll",
        "width": 1000,
        "height": 700,
        "minWidth": 500,
        "minHeight": 500,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --force-color-profile=srgb --disable-color-correct-rendering"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../server/dist/camera-roll-server/**/*": "server-bin"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
